{
  "name": "illusions",
  "version": "1.2.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "author": {
    "name": "幾田花",
    "url": "https://iktahana.com",
    "email": "illusions@iktahana.com"
  },
  "main": "dist-main/main.js",
  "scripts": {
    "type-check": "tsc --noEmit",
    "dev": "npm run type-check && next dev -p 3010",
    "build": "npm run type-check && npm run generate:credits && next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,css,md}\"",
    "prepare": "husky",
    "download:fonts": "node scripts/download-local-fonts.mjs",
    "bundle:electron": "node scripts/bundle-electron.mjs",
    "electron:dev": "npm run bundle:electron && concurrently \"next dev -p 3020\" \"wait-on http://localhost:3020 && cross-env ELECTRON_DEV=1 electron .\"",
    "electron:build": "npm run type-check && npm run generate:credits && cross-env ELECTRON_BUILD=1 next build && npm run bundle:electron && electron-builder",
    "build:quicklook": "node -e \"if(process.platform==='darwin'){const {execSync}=require('child_process');execSync('bash scripts/build-quicklook.sh',{stdio:'inherit'});}else{console.log('build:quicklook skipped (macOS only)');}\" ",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "generate:credits": "npx tsx scripts/generate-credits.ts",
    "generate:store-assets": "node scripts/generate-store-assets.mjs",
    "clean:local": "node scripts/clean-local-artifacts.mjs",
    "postinstall": "node -e \"if(!process.env.VERCEL){require('child_process').execSync('electron-builder install-app-deps',{stdio:'inherit'})}\""
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-context-menu": "^2.3.0",
    "@serwist/next": "^9.5.11",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/xterm": "^6.0.0",
    "archiver": "^7.0.1",
    "assert": "^2.1.0",
    "better-sqlite3": "^12.10.1",
    "browserify-zlib": "^0.2.0",
    "buffer": "^6.0.3",
    "dockview-react": "^6.6.1",
    "docx": "^9.7.1",
    "electron-log": "^5.4.4",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.9",
    "fflate": "^0.8.3",
    "kuromoji": "^0.1.2",
    "kyujitai": "^1.3.0",
    "markdown-it": "^14.2.0",
    "next": "^16.2.9",
    "node-pty": "^1.0.0",
    "openai": "^6.42.0",
    "pako": "^2.1.0",
    "path-browserify": "^1.0.1",
    "process": "^0.11.10",
    "stream-browserify": "^3.0.0",
    "util": "^0.12.5"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@milkdown/core": "^7.21.2",
    "@milkdown/ctx": "^7.21.2",
    "@milkdown/plugin-clipboard": "^7.21.2",
    "@milkdown/plugin-cursor": "^7.21.2",
    "@milkdown/plugin-history": "^7.21.2",
    "@milkdown/plugin-listener": "^7.21.2",
    "@milkdown/plugin-prism": "^7.21.2",
    "@milkdown/preset-commonmark": "^7.21.2",
    "@milkdown/preset-gfm": "^7.21.2",
    "@milkdown/react": "^7.21.2",
    "@milkdown/theme-nord": "^7.21.2",
    "@milkdown/utils": "^7.5.1",
    "@prosemirror-adapter/react": "^0.5.3",
    "@types/archiver": "^7.0.0",
    "@types/diff": "^8.0.0",
    "@types/kuromoji": "^0.1.3",
    "@types/license-checker": "^25.0.6",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.8",
    "autoprefixer": "^10.5.0",
    "clsx": "^2.1.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "dexie": "^4.4.3",
    "diff": "^9.0.0",
    "electron": "^41.4.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "license-checker": "^25.0.1",
    "lint-staged": "^17.0.7",
    "lucide-react": "^1.18.0",
    "postcss": "^8.5.14",
    "prettier": "^3.8.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "serwist": "^9.5.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3",
    "unist-util-visit": "^5.0.0",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.10"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{js,mjs}": [
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "build": {
    "appId": "com.iktahana.illusions",
    "productName": "illusions",
    "directories": {
      "app": ".",
      "output": "dist-electron"
    },
    "icon": "build/icon.png",
    "files": [
      "dist-main/**/*",
      "out/**/*",
      "!node_modules/**/*"
    ],
    "asarUnpack": [
      "dist-main/node_modules/**"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Iktahana",
        "repo": "illusions"
      }
    ],
    "protocols": [
      {
        "name": "illusions",
        "schemes": [
          "illusions"
        ]
      }
    ],
    "afterPack": "scripts/embed-quicklook.js",
    "afterSign": "scripts/notarize.js",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "UTExportedTypeDeclarations": [
          {
            "UTTypeIdentifier": "com.iktahana.illusions.mdi",
            "UTTypeDescription": "illusions MDI Document",
            "UTTypeConformsTo": [
              "public.plain-text"
            ],
            "UTTypeTagSpecification": {
              "public.filename-extension": [
                "mdi"
              ],
              "public.mime-type": "text/markdown"
            }
          }
        ]
      },
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "fileAssociations": [
        {
          "ext": "mdi",
          "name": "illusions MDI Document",
          "icon": "build/mdi-icon.icns",
          "role": "Editor"
        }
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "appx",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "fileAssociations": [
        {
          "ext": "mdi",
          "name": "illusions MDI Document",
          "icon": "build/mdi-icon.ico",
          "description": "illusions MDI Document"
        }
      ]
    },
    "appx": {
      "identityName": "74B619E8.illusions-AI",
      "publisher": "CN=700D90DC-B687-4899-8C1E-2E1B85A6195C",
      "publisherDisplayName": "幾田花",
      "applicationId": "IllusionsApp",
      "displayName": "illusions「幻」 - 執筆・AI校正ツール",
      "languages": [
        "ja-JP"
      ],
      "backgroundColor": "#1a1a1a"
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Office",
      "desktop": {
        "entry": {
          "Name": "illusions",
          "Comment": "AI搭載日本語小説エディタ",
          "Keywords": "小説;執筆;日本語;エディタ;AI;novel;writing;japanese;editor;",
          "MimeType": "application/x-mdi;"
        }
      },
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        }
      ],
      "fileAssociations": [
        {
          "ext": "mdi",
          "name": "illusions MDI Document",
          "icon": "build/mdi-icon.png",
          "mimeType": "application/x-mdi",
          "description": "illusions MDI Document"
        }
      ]
    }
  }
}
