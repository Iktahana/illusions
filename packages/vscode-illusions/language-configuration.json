{
  "comments": {
    "blockComment": ["<!--", "-->"]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "「", "close": "」" },
    { "open": "『", "close": "』" },
    { "open": "（", "close": "）" },
    { "open": "【", "close": "】" },
    { "open": "〔", "close": "〕" },
    { "open": "《", "close": "》" }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["「", "」"],
    ["『", "』"],
    ["（", "）"],
    ["【", "】"],
    ["*", "*"],
    ["_", "_"],
    ["`", "`"]
  ],
  "wordPattern": "[\\p{Script=Han}\\p{Script=Hiragana}\\p{Script=Katakana}\\p{Script=Latin}\\d]+"
}
