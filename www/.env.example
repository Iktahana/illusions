# Local development environment variables
#
# The downloads page reads release data from /release-data.json.
# This file is pre-fetched at build time during CI (deploy-www.yml).
#
# For local development, you can generate this file manually:
#   curl -sSf \
#        -H "Accept: application/vnd.github.v3+json" \
#        "https://api.github.com/repos/Iktahana/illusions/releases/latest" \
#        -o public/release-data.json
